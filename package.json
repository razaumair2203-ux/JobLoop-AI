{
  "name": "jobloop-ai",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "turbo dev --filter=@jobloop/web",
    "dev:mobile": "cd apps/mobile && npx expo start",
    "build:web": "turbo build --filter=@jobloop/web"
  },
  "devDependencies": {
    "turbo": "^2"
  },
  "packageManager": "npm@11.8.0"
}
